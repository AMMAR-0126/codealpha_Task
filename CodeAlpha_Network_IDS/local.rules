# Rule 1 - Ping detect 
alert icmp any any -> any any (msg:"ICMP Ping Detected!"; sid:1000001; rev:1;)

# Rule 2 - Port Scan detect 
alert tcp any any -> any any (msg:"TCP Port Scan!"; flags:S; sid:1000002; rev:1;)

# Rule 3 - SSH attempt detect 
alert tcp any any -> any 22 (msg:"SSH Login Attempt!"; sid:1000003; rev:1;)

# Rule 4 - HTTP traffic detect 
alert tcp any any -> any 80 (msg:"HTTP Traffic Detected!"; sid:1000004; rev:1;)# $Id: local.rules,v 1.11 2004/07/23 20:15:44 bmc Exp $
